{
  "name": "mytaxreturn-au",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "test": "node --experimental-strip-types src/__tests__/run-tests.ts",
    "test:report": "node --experimental-strip-types src/__tests__/run-tests.ts && open test-report.html",
    "lint": "eslint .",
    "format:check": "prettier --check \"*.{js,json,md,ts,tsx}\" \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"*.{js,json,md,ts,tsx}\" \"src/**/*.{ts,tsx}\"",
    "type-check": "npx tsc --noEmit",
    "type-check:watch": "npx tsc --noEmit --watch",
    "build": "npx tsc",
    "build:watch": "npx tsc --watch"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.4",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "^53.0.0",
    "expo-file-system": "~18.1.11",
    "expo-linear-gradient": "~14.1.5",
    "expo-sharing": "~13.1.5",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-web": "^0.20.0"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3"
  }
}
