{
  "name": "mytaxreturn-au",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "test": "node --experimental-strip-types src/__tests__/run-tests.ts",
    "test:report": "node --experimental-strip-types src/__tests__/run-tests.ts && open test-report.html",
    "lint": "eslint .",
    "format:check": "prettier --check \"*.{js,json,md,ts,tsx}\" \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"*.{js,json,md,ts,tsx}\" \"src/**/*.{ts,tsx}\"",
    "type-check": "npx tsc --noEmit",
    "type-check:watch": "npx tsc --noEmit --watch",
    "eas:whoami": "npx eas-cli@20.1.0 whoami",
    "eas:build:ios:preview-simulator": "npx eas-cli@20.1.0 build --profile preview-simulator --platform ios",
    "eas:build:ios:preview": "npx eas-cli@20.1.0 build --profile preview --platform ios",
    "eas:build:android:preview": "npx eas-cli@20.1.0 build --profile preview --platform android",
    "eas:build:ios:production": "npx eas-cli@20.1.0 build --profile production --platform ios",
    "eas:build:android:production": "npx eas-cli@20.1.0 build --profile production --platform android",
    "build": "npx tsc",
    "build:watch": "npx tsc --watch"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@sentry/react-native": "~6.14.0",
    "expo": "~53.0.27",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-linear-gradient": "~14.1.5",
    "expo-sharing": "~13.1.5",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "^0.79.6",
    "react-native-web": "^0.20.0"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~9.2.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3"
  }
}
